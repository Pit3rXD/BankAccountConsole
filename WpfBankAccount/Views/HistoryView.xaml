<UserControl x:Class="WpfBankAccount.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfBankAccount.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Text="Transaction History"
                   FontSize="24"
                   FontWeight="Bold"
                   Grid.ColumnSpan="3"/>

        <!--Owner-->
        <TextBlock Margin="10,0,0,0"
                   Grid.Row="1" 
                   Grid.Column="0"
                   Text="Owner:"
                   FontWeight="Bold"/>

        <TextBlock Grid.Row="1"
                   Grid.Column="1"
                   Text="{Binding OwnerName}"/>

        <!--Account number-->
        <TextBlock Margin="10,0,0,0"
                   Grid.Row="2" 
                   Grid.Column="0"
                   Text="Account Number: ">
            
        </TextBlock>


        <TextBlock Grid.Row="2" 
                   Grid.Column="1"
                   Text="{Binding AccountNumber}"/>

        <!--Balance-->
        <TextBlock Margin="10,0,0,0"
                   Grid.Row="3"
                   Grid.Column="0"
                   Text="Balance"
                   FontWeight="Bold"/>

        <TextBlock Grid.Row="3"
                   Grid.Column="1"
                   Text="{Binding Balance}"
                   FontSize="16"
                   FontWeight="Bold"/>

        <!--Table-->
        <DataGrid Grid.Row="4"
                  Grid.Column="0"
                  Grid.ColumnSpan="3"
                  ItemsSource="{Binding Transactions}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="0,10,0,10">

            <DataGrid.Columns>
                <DataGridTextColumn  Header="Data"  Binding="{Binding Date}"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type}"/>
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount}"/>
                <DataGridTextColumn Header="Balance" Binding="{Binding BalanceAfter}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!--Back button-->
        <Button Grid.Row="5"
                Grid.Column="2"
                Content="Back"
                Width="100"
                HorizontalAlignment="Center"
                Command="{Binding BackCommand}"
                Margin="0,0,0,10"/>
    </Grid>
</UserControl>
